# Copy to .env.local and replace with real values (see src/env.js for validation).

NODE_ENV=development

# Supabase — Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Meta app secret — POST webhook signature (X-Hub-Signature-256), NOT the verify token
WHATSAPP_APP_SECRET=
# Delivery partner webhooks — HMAC X-Signature-256, min 32 characters
DELIVERY_WEBHOOK_SECRET=

# Upstash Redis — REST API tab
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Random 32+ chars — cron / internal webhooks
CRON_SECRET=0123456789abcdef0123456789abcdef

NEXT_PUBLIC_ROOT_DOMAIN=platform.localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CI / Docker builds only
# SKIP_ENV_VALIDATION=true
