## API route pattern — copy this template

```ts
import { NextResponse, type NextRequest } from "next/server"
import { withAuth, withRateLimit, ok, fail, NotFoundError, ValidationError } from "@/lib/api"
import { createClient } from "@/lib/supabase/server"
import { mySchema } from "@/lib/validations"
import { assertStoreOwnership } from "@/lib/utils"

export const GET = withRateLimit()(
  withAuth(async (req, { auth, params }) => {
    const { id } = await params
    const supabase = await createClient()

    await assertStoreOwnership(supabase, id, auth.user.id)

    const { data, error } = await supabase
      .from("stores")
      .select("*")
      .eq("id", id)
      .single()

    if (error ?? !data) return fail(new NotFoundError("Boutique"))

    return ok(data)
  })
)

export const PATCH = withRateLimit()(
  withAuth(async (req, { auth, params }) => {
    const { id } = await params
    const body = await req.json() as unknown
    const parsed = mySchema.safeParse(body)
    if (!parsed.success) return fail(new ValidationError(parsed.error.errors[0]?.message ?? "Invalide"))

    const supabase = await createClient()
    await assertStoreOwnership(supabase, id, auth.user.id)

    const { data, error } = await supabase
      .from("stores")
      .update(parsed.data)
      .eq("id", id)
      .select()
      .single()

    if (error) return fail(error)
    return ok(data)
  })
)
```

