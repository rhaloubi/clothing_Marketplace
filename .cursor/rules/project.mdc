## Validation — always Zod, always before DB

All schemas live in `src/lib/validations/index.ts`.

```ts
import { createProductSchema } from "@/lib/validations"

const parsed = createProductSchema.safeParse(body)
if (!parsed.success) {
  return fail(new ValidationError(
    parsed.error.errors[0]?.message ?? "Invalide",
    // Optional: field-level errors for forms
    Object.fromEntries(parsed.error.errors.map(e => [e.path.join("."), e.message]))
  ))
}
// Now safe to use parsed.data
```

