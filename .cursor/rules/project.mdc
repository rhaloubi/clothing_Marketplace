## Security layer — `src/lib/api/`

Always import from `@/lib/api` (the index re-exports everything).

### Route wrappers — compose these

```ts
import { withAuth, withRateLimit, withPlan, ok, fail, NotFoundError } from "@/lib/api"

// Public route — just rate limited
export const POST = withRateLimit("checkout")(async (req) => {
  return ok({ done: true })
})

// Authenticated route
export const GET = withRateLimit()(
  withAuth(async (req, { auth }) => {
    // auth.user.id, auth.profile guaranteed non-null
    return ok({ userId: auth.user.id })
  })
)

// Authenticated + plan feature gate
export const GET = withRateLimit()(
  withAuth(
    withPlan("has_analytics")(async (req, { auth }) => {
      // auth.plan.planName, auth.plan.features, auth.plan.maxProducts
      return ok({ plan: auth.plan.planName })
    })
  )
)

// Webhook (HMAC signature verification)
export const POST = withWebhook("whatsapp")(async (req, { rawBody }) => {
  const payload = JSON.parse(rawBody) as unknown
  return ok({ received: true })
})

// Cron job
export const GET = withWebhook("cron")(async (req, { rawBody }) => {
  // Protected by Authorization: Bearer <CRON_SECRET>
  return ok({ ran: true })
})
```

### Response helpers — always use these, never raw NextResponse

```ts
return ok({ store })            // 200
return ok({ store }, 201)       // 201 (or use created())
return created({ store })       // 201
return noContent()              // 204 (DELETE)
return fail(new NotFoundError("Boutique"))          // 404
return fail(new ValidationError("Invalide", { name: "Requis" })) // 400
return fail(new ForbiddenError())                   // 403
return fail(new ConflictError("Ce slug est pris"))  // 409
return fail(err)                // catches anything, logs unknowns as 500
```

### Rate limit presets

```ts
"auth"     // 10 req/min  — login, signup
"checkout" // 20 req/min  — guest order placement
"analytics"// 120 req/min — storefront event tracking
"api"      // 60 req/min  — default for dashboard routes
"upload"   // 30 req/min  — file uploads
"webhook"  // 500 req/min — delivery provider callbacks
```

